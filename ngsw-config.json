{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ],
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "animals-api",
      "urls": ["/api/animals**", "/api/species**"],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "10m",
        "timeout": "5s",
        "strategy": "freshness"
      }
    },
    {
      "name": "reports-api",
      "urls": ["/api/reports**"],
      "cacheConfig": {
        "maxSize": 30,
        "maxAge": "5m",
        "timeout": "5s",
        "strategy": "freshness"
      }
    }
  ]
}
